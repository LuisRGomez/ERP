# App
APP_ENV=development
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
FRONTEND_URL=http://localhost:5173

# Base de datos
DATABASE_URL=postgresql://factura:factura@localhost:5432/facturadb

# Redis
REDIS_URL=redis://localhost:6379

# ARCA / AfipSDK
AFIPSDK_ACCESS_TOKEN=
AFIPSDK_ENVIRONMENT=testing  # testing | production

# Email (para envío de facturas)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=facturas@tudominio.com

# Storage (PDFs de facturas)
STORAGE_BACKEND=local  # local | s3
AWS_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
LOCAL_STORAGE_PATH=./storage
